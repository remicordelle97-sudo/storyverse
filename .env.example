# AI Keys
ANTHROPIC_API_KEY=
GOOGLE_AI_KEY=
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Auth
# Required in production. Must be at least 32 random characters. The
# server will refuse to boot in production if this is unset/short.
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars-long
# Comma-separated list of emails that are auto-promoted to the "admin"
# role on first sign-in. Case-insensitive. Leave empty to disable.
ADMIN_EMAILS=
# Cloudflare R2 (image storage — optional, falls back to local filesystem)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=storyverse-images
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Stripe (for premium subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
APP_URL=https://your-app.up.railway.app

# Lulu (print-on-demand)
# Sandbox: https://api.sandbox.lulu.com  /  Production: https://api.lulu.com
LULU_API_BASE_URL=https://api.sandbox.lulu.com
LULU_CLIENT_KEY=
LULU_CLIENT_SECRET=
# Default product SKU. Look up an exact SKU at
# https://developers.lulu.com/price-calculator. For thin children's
# storybooks, prefer saddle-stitched booklet (SB) — it allows fewer
# pages than perfect-bound paperback (PB, 32 minimum) and is the
# typical format for short children's books.
# Format: <trim>X<trim><ink><quality><binding><paper><cover><linen><region>
LULU_DEFAULT_POD_PACKAGE_ID=

PORT=3001
# Local development: use a local PostgreSQL instance
DATABASE_URL=postgresql://user:password@localhost:5432/storyverse
# Railway: this is auto-populated when you add a PostgreSQL plugin

# Background workers
# Redis URL for BullMQ. If unset, queues are disabled and routes fall
# back to in-process execution (fine for local dev, not safe for
# multi-instance production).
REDIS_URL=
# Set to "false" once a separate worker service is provisioned, so the
# web process stops running workers in-process. Default (unset/anything
# else) keeps the single-process behavior.
WORKER_INLINE=
# Per-vendor worker concurrency. Defaults: 2 / 2. Tune up only after
# observing queue depth, runtime, and 429 rates.
CLAUDE_QUEUE_CONCURRENCY=2
GEMINI_QUEUE_CONCURRENCY=2
