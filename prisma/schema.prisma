generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(uuid())
  googleId         String     @unique
  email            String     @unique
  name             String
  role             String     @default("user")
  plan             String     @default("free")
  stripeCustomerId String?    @unique
  picture          String     @default("")
  onboardedAt      DateTime?
  createdAt        DateTime   @default(now())
  universes        Universe[]
  stories          Story[]
  printOrders      PrintOrder[]
}

model Universe {
  id                 String      @id @default(uuid())
  userId             String
  name               String
  settingDescription String
  themes             String
  avoidThemes        String      @default("")
  styleReferenceUrl  String      @default("")
  isPublic           Boolean     @default(false)
  isTemplate         Boolean     @default(false)
  // True for universes cloned from a preset (admin-curated template).
  // Preset clones do not count toward the user's universe quota.
  fromPreset         Boolean     @default(false)
  createdAt          DateTime    @default(now())
  user               User        @relation(fields: [userId], references: [id])
  characters         Character[]
  stories            Story[]
}

model Character {
  id                    String           @id @default(uuid())
  universeId            String
  name                  String
  speciesOrType         String
  personalityTraits     String
  appearance            String
  outfit                String           @default("")
  relationshipArchetype String           @default("")
  referenceImageUrl     String           @default("")
  role                  String           @default("main")
  createdAt             DateTime         @default(now())
  universe              Universe         @relation(fields: [universeId], references: [id])
  storyAppearances      StoryCharacter[]
}

model Story {
  id               String           @id @default(uuid())
  universeId       String
  createdById      String?
  title            String
  mood             String
  language         String           @default("en")
  ageGroup         String
  hasIllustrations Boolean          @default(false)
  status           String           @default("draft")
  isPublic         Boolean          @default(false)
  debugPlanPrompt  String           @default("")
  debugWritePrompt String           @default("")
  debugPlan        String           @default("")
  debugStructure   String           @default("")
  createdAt        DateTime         @default(now())
  universe         Universe         @relation(fields: [universeId], references: [id])
  createdBy        User?            @relation(fields: [createdById], references: [id])
  scenes           Scene[]
  characters       StoryCharacter[]
  printOrders      PrintOrder[]

  // Speeds up the monthly quota count: WHERE createdById=? AND createdAt >= ? AND hasIllustrations=?.
  @@index([createdById, createdAt, hasIllustrations])
}

model Scene {
  id          String @id @default(uuid())
  storyId     String
  sceneNumber Int
  content     String
  imageUrl    String @default("")
  imagePrompt String @default("")
  story       Story  @relation(fields: [storyId], references: [id])
}

// Print-on-demand orders fulfilled via Lulu. Phase 1 lifecycle is
// abbreviated (sandbox testing only): "draft" → "submitted" → terminal.
// Production lifecycle adds payment + Lulu webhook states.
model PrintOrder {
  id                  String   @id @default(uuid())
  userId              String
  storyId             String
  status              String   @default("draft")
  // Lulu API state
  luluPrintJobId      String?
  luluTrackingUrl     String?
  // Pricing snapshot (cents) — frozen at quote time so a later Lulu
  // price change doesn't retroactively rewrite what the user paid.
  luluPrintCostCents  Int?
  luluShippingCostCents Int?
  customerPriceCents  Int?
  // Stripe wiring (Phase 2). Nullable now.
  stripeSessionId     String?
  stripePaymentId     String?
  // Shipping
  shippingAddress     String   @default("")  // JSON-encoded address blob
  // Source PDFs (R2 URLs) snapshotted for re-submission and audit.
  coverPdfUrl         String   @default("")
  interiorPdfUrl      String   @default("")
  // Failure / cancellation reason for support
  rejectionReason     String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id])
  story               Story    @relation(fields: [storyId], references: [id])

  @@index([userId, createdAt])
}

model StoryCharacter {
  storyId     String
  characterId String
  roleInStory String    @default("featured")
  story       Story     @relation(fields: [storyId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
  @@id([storyId, characterId])
}

