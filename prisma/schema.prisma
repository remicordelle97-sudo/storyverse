generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  googleId         String          @unique
  email            String          @unique
  name             String
  role             String          @default("user")
  plan             String          @default("free")
  stripeCustomerId String?         @unique
  picture          String          @default("")
  onboardedAt      DateTime?
  // JSON-encoded ShippingAddress saved by the user for one-click
  // print-on-demand checkout. Empty string means unset (the cart
  // page prompts them to add one before checkout). Captured during
  // onboarding (skippable) and editable from /account.
  shippingAddress  String          @default("")
  createdAt        DateTime        @default(now())
  universes        Universe[]
  stories          Story[]
  printOrders      PrintOrder[]
  generationJobs   GenerationJob[]
}

model Universe {
  id                 String          @id @default(uuid())
  userId             String
  name               String
  settingDescription String
  themes             String
  avoidThemes        String          @default("")
  styleReferenceUrl  String          @default("")
  isPublic           Boolean         @default(false)
  isTemplate         Boolean         @default(false)
  // True for universes cloned from a preset (admin-curated template).
  // Preset clones do not count toward the user's universe quota.
  fromPreset         Boolean         @default(false)
  // Lifecycle status. Existing rows default to "ready" so the column is
  // safe to add without a data migration. The async creation pipeline
  // (introduced in a later PR) will explicitly write:
  //   queued | building | illustrating_assets | ready | failed
  status             String          @default("ready")
  createdAt          DateTime        @default(now())
  user               User            @relation(fields: [userId], references: [id])
  characters         Character[]
  stories            Story[]
  generationJobs     GenerationJob[]

  @@index([userId, createdAt])
  @@index([isPublic, createdAt])
  @@index([isTemplate, createdAt])
}

model Character {
  id                    String           @id @default(uuid())
  universeId            String
  name                  String
  speciesOrType         String
  personalityTraits     String
  appearance            String
  outfit                String           @default("")
  relationshipArchetype String           @default("")
  referenceImageUrl     String           @default("")
  role                  String           @default("main")
  createdAt             DateTime         @default(now())
  universe              Universe         @relation(fields: [universeId], references: [id])
  storyAppearances      StoryCharacter[]
}

model Story {
  id               String           @id @default(uuid())
  universeId       String
  createdById      String?
  title            String
  mood             String
  language         String           @default("en")
  ageGroup         String
  hasIllustrations Boolean          @default(false)
  // Lifecycle status. Currently the synchronous flow only writes
  // "illustrating" and "published"; "draft" is the table default. The
  // async pipeline (introduced in a later PR) will expand to:
  //   queued | generating_text | illustrating | published
  //   | failed_text | failed_illustration
  status           String           @default("draft")
  isPublic         Boolean          @default(false)
  debugPlanPrompt  String           @default("")
  debugWritePrompt String           @default("")
  debugPlan        String           @default("")
  debugStructure   String           @default("")
  createdAt        DateTime         @default(now())
  universe         Universe         @relation(fields: [universeId], references: [id])
  createdBy        User?            @relation(fields: [createdById], references: [id])
  scenes           Scene[]
  characters       StoryCharacter[]
  printOrders      PrintOrder[]
  generationJobs   GenerationJob[]

  // Speeds up the monthly quota count: WHERE createdById=? AND createdAt >= ? AND hasIllustrations=?.
  @@index([createdById, createdAt, hasIllustrations])
  @@index([universeId, createdAt])
  @@index([isPublic, createdAt])
  @@index([status])
}

model Scene {
  id          String @id @default(uuid())
  storyId     String
  sceneNumber Int
  content     String
  imageUrl    String @default("")
  imagePrompt String @default("")
  story       Story  @relation(fields: [storyId], references: [id])
}

// Print-on-demand orders fulfilled via Lulu.
//
// One PrintOrder = one printed copy of one story. Multiple PrintOrder
// rows can share a `printBatchId` to be submitted to Lulu as a single
// print-job with multiple line_items, paid for in a single Stripe
// Checkout session (the cart-checkout flow). printBatchId is null
// until the batch checkout assigns one.
//
// Status vocabulary:
//   cart                — added to cart, not yet checked out (no batch yet)
//   pending_payment     — Stripe Checkout session created, awaiting webhook
//   paid                — Stripe webhook confirmed payment
//   submitted           — Lulu accepted the print job
//   in_production       — Lulu started printing
//   shipped             — left Lulu's facility (luluTrackingUrl set)
//   delivered           — confirmed delivery
//   cancelled           — user/admin cancelled before submission
//   failed              — Lulu rejected, or submission errored
//   refunded            — payment refunded
//   draft               — admin smoke-test path (no payment)
model PrintOrder {
  id                    String   @id @default(uuid())
  userId                String
  storyId               String
  // Groups orders that ship together as one Lulu print-job. Null
  // while the order is in cart, or for legacy single-book orders
  // that predate the cart flow.
  printBatchId          String?
  status                String   @default("draft")
  // Lulu API state. luluPrintJobId is shared across every order in
  // the same batch (one Lulu job, many line items).
  luluPrintJobId        String?
  luluTrackingUrl       String?
  // Pricing snapshot (cents) — frozen at quote time so a later Lulu
  // price change doesn't retroactively rewrite what the user paid.
  luluPrintCostCents    Int?
  luluShippingCostCents Int?
  customerPriceCents    Int?
  // Stripe wiring. Same session id is shared across every order in
  // the same batch (one Checkout session, one payment).
  stripeSessionId       String?
  stripePaymentId       String?
  // Shipping snapshot — taken from User.shippingAddress at checkout
  // so a later profile edit doesn't rewrite the destination of a
  // print-job that's already with Lulu.
  shippingAddress       String   @default("") // JSON-encoded address blob
  // Source PDFs (R2 URLs) snapshotted for re-submission and audit.
  coverPdfUrl           String   @default("")
  interiorPdfUrl        String   @default("")
  // Failure / cancellation reason for support
  rejectionReason       String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id])
  story                 Story    @relation(fields: [storyId], references: [id])

  @@index([userId, createdAt])
  // Batch lookup: cart endpoints group by printBatchId, webhook
  // updates every row in a batch by luluPrintJobId.
  @@index([printBatchId])
  @@index([luluPrintJobId])
}

model StoryCharacter {
  storyId     String
  characterId String
  roleInStory String    @default("featured")
  story       Story     @relation(fields: [storyId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])

  @@id([storyId, characterId])
}

// Worker-side metadata for an async generation task. The user-facing
// status lives on Story.status / Universe.status; this row carries the
// retry, locking, progress, and audit detail. One entity may have
// multiple jobs over its lifetime (e.g. story_text then story_images,
// or a retried universe_build).
//
// kind:    story_text | story_images | universe_build | universe_images
// status:  queued | running | completed | failed | cancelled
// step:    free-form, kind-specific (e.g. "planning", "writing",
//          "refining", "illustrating_scene_3"). Surfaced in the
//          status-polling endpoint.
//
// lockedAt + lockedBy form the claim mechanism for resume / retry: a
// worker sets both atomically before processing and clears them on
// completion. Stale locks (lockedAt older than the job timeout) can be
// reclaimed by another worker.
model GenerationJob {
  id              String    @id @default(uuid())
  kind            String
  status          String    @default("queued")
  ownerId         String
  storyId         String?
  universeId      String?
  payload         Json      @default("{}")
  step            String    @default("")
  progressPercent Int       @default(0)
  attempts        Int       @default(0)
  lastError       String    @default("")
  lockedAt        DateTime?
  lockedBy        String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  owner           User      @relation(fields: [ownerId], references: [id])
  story           Story?    @relation(fields: [storyId], references: [id])
  universe        Universe? @relation(fields: [universeId], references: [id])

  // Worker poll: WHERE status='queued' AND kind=? ORDER BY createdAt ASC.
  @@index([status, kind, createdAt])
  // Stale-lock sweep: WHERE lockedAt < now() - timeout.
  @@index([lockedAt])
  // Lookups by entity for status endpoints and audit trails.
  @@index([storyId])
  @@index([universeId])
  @@index([ownerId, createdAt])
}
