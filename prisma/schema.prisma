generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(uuid())
  googleId         String     @unique
  email            String     @unique
  name             String
  role             String     @default("user")
  plan             String     @default("free")
  stripeCustomerId String?    @unique
  picture          String     @default("")
  createdAt        DateTime   @default(now())
  universes        Universe[]
}

model Universe {
  id                   String          @id @default(uuid())
  userId               String
  name                 String
  settingDescription   String
  sensoryDetails       String          @default("")
  worldRules           String          @default("")
  scaleAndGeography    String          @default("")
  themes               String
  illustrationStyle    String          @default("storybook")
  illustrationsEnabled Boolean         @default(true)
  avoidThemes          String          @default("")
  styleReferenceUrl    String          @default("")
  createdAt            DateTime        @default(now())
  user                 User            @relation(fields: [userId], references: [id])
  characters           Character[]
  locations            Location[]
  stories              Story[]
}

model Location {
  id                String   @id @default(uuid())
  universeId        String
  name              String
  description       String
  role              String   @default("discovery")
  mood              String   @default("")
  lighting          String   @default("")
  landmarks         String   @default("")
  referenceImageUrl String   @default("")
  createdAt         DateTime @default(now())
  universe          Universe @relation(fields: [universeId], references: [id])
}

model Character {
  id                String           @id @default(uuid())
  universeId        String
  name              String
  speciesOrType     String
  personalityTraits    String
  appearance           String
  outfit               String           @default("")
  specialDetail        String           @default("")
  relationshipArchetype String          @default("")
  referenceImageUrl    String           @default("")
  role                 String           @default("main")
  createdAt         DateTime         @default(now())
  universe          Universe         @relation(fields: [universeId], references: [id])
  storyAppearances  StoryCharacter[]
}

model Story {
  id               String           @id @default(uuid())
  universeId       String
  title            String
  mood             String
  language         String           @default("en")
  ageGroup         String
  hasIllustrations Boolean          @default(false)
  status           String           @default("draft")
  isPublic         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  universe         Universe         @relation(fields: [universeId], references: [id])
  scenes           Scene[]
  characters       StoryCharacter[]
}

model Scene {
  id          String @id @default(uuid())
  storyId     String
  sceneNumber Int
  content     String
  imageUrl    String @default("")
  imagePrompt String @default("")
  imageSeed   Int    @default(0)
  imageEngine String @default("")
  story       Story  @relation(fields: [storyId], references: [id])
}

model StoryCharacter {
  storyId     String
  characterId String
  roleInStory String    @default("featured")
  story       Story     @relation(fields: [storyId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
  @@id([storyId, characterId])
}

